{
    "openapi": "3.0.0",
    "info": {
        "title": "API Agenda de Contacts",
        "description": "Documentação da API de Agenda de Contacts",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://127.0.0.1:8000",
            "description": "Servidor Local"
        }
    ],
    "paths": {
        "/api/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Faz login do usuário",
                "operationId": "222b2625838e3c57e017987f73598fda",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "example": "user@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "password"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login realizado com sucesso"
                    }
                }
            }
        },
        "/api/register": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Registra um novo usuário",
                "operationId": "8e4e3cb7b46126f4696379d3c7eeb4ad",
                "parameters": [
                    {
                        "name": "name",
                        "in": "query",
                        "description": "name do usuário",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "email",
                        "in": "query",
                        "description": "Email do usuário",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "password",
                        "in": "query",
                        "description": "Senha do usuário",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Usuário registrado com sucesso"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/logout": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Realiza logout do usuário autenticado",
                "operationId": "ad65cbbd4e9f201619eae184a5961a98",
                "responses": {
                    "200": {
                        "description": "Logout realizado com sucesso"
                    },
                    "401": {
                        "description": "Usuário não autenticado"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/contacts": {
            "get": {
                "tags": [
                    "Contacts"
                ],
                "summary": "Lista todos os Contacts",
                "operationId": "bc39494d59500e2d75e6f6648b43c8de",
                "parameters": [
                    {
                        "name": "search",
                        "in": "query",
                        "description": "Termo de pesquisa para filtrar Contacts pelo name",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "phone",
                        "in": "query",
                        "description": "Buscar pelo phone",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "favorite",
                        "in": "query",
                        "description": "Filtrar favorites",
                        "required": false,
                        "schema": {
                            "type": "boolean"
                        }
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "description": "Número da página",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 1
                        }
                    },
                    {
                        "name": "per_page",
                        "in": "query",
                        "description": "Quantidade de contatos por página",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 10
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Lista de Contacts retornada com sucesso"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Contacts"
                ],
                "summary": "Cria um novo Contact",
                "operationId": "779a1f2268bae1138e7ea7843dd88d90",
                "parameters": [
                    {
                        "name": "name",
                        "in": "query",
                        "description": "name do Contact",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "phone",
                        "in": "query",
                        "description": "phone do Contact",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "email",
                        "in": "query",
                        "description": "Email do Contact",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "favorite",
                        "in": "query",
                        "description": "Indica se o Contact é favorite",
                        "required": false,
                        "schema": {
                            "type": "boolean"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Contact criado com sucesso"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/contacts/{Contact}": {
            "get": {
                "tags": [
                    "Contacts"
                ],
                "summary": "Exibe um Contact",
                "operationId": "d0d60696adc4804f953f5b3e37407048",
                "parameters": [
                    {
                        "name": "Contact",
                        "in": "path",
                        "description": "ID do Contact",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Contact retornado com sucesso"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "put": {
                "tags": [
                    "Contacts"
                ],
                "summary": "Atualiza um Contact",
                "operationId": "3c4aae286067269fe8c8b3162c0059d1",
                "parameters": [
                    {
                        "name": "Contact",
                        "in": "path",
                        "description": "ID do Contact",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "name",
                        "in": "query",
                        "description": "name do Contact",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "phone",
                        "in": "query",
                        "description": "phone do Contact",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "email",
                        "in": "query",
                        "description": "Email do Contact",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "favorite",
                        "in": "query",
                        "description": "Indica se o Contact é favorite",
                        "required": false,
                        "schema": {
                            "type": "boolean"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Contact atualizado com sucesso"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Contacts"
                ],
                "summary": "Remove um Contact",
                "description": "Remove the specified resource from storage.",
                "operationId": "96ed7c648f93c6e4a2f97abb672b9abc",
                "parameters": [
                    {
                        "name": "Contact",
                        "in": "path",
                        "description": "ID do Contact",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Contact removido com sucesso"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/contacts/{Contact}/favorite": {
            "patch": {
                "tags": [
                    "Contacts"
                ],
                "summary": "Atualiza o status de favorite de um Contact",
                "operationId": "c7995e8033cef9111bb944cc47af9e4e",
                "parameters": [
                    {
                        "name": "Contact",
                        "in": "path",
                        "description": "ID do Contact",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Status de favorite atualizado com sucesso"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/dashboard": {
            "get": {
                "tags": [
                    "Dashboard"
                ],
                "summary": "Dashboard da agenda",
                "description": "Retorna um resumo da agenda do usuário autenticado.",
                "operationId": "dashboard",
                "responses": {
                    "200": {
                        "description": "Dashboard retornado com sucesso",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "total_Contacts": {
                                            "type": "integer",
                                            "example": 15
                                        },
                                        "total_favorites": {
                                            "type": "integer",
                                            "example": 6
                                        },
                                        "Contacts_mes": {
                                            "type": "integer",
                                            "example": 3
                                        },
                                        "ultimos_Contacts": {
                                            "type": "array",
                                            "items": {
                                                "properties": {
                                                    "id": {
                                                        "type": "integer",
                                                        "example": 20
                                                    },
                                                    "name": {
                                                        "type": "string",
                                                        "example": "Carlos"
                                                    },
                                                    "phone": {
                                                        "type": "string",
                                                        "example": "(38)99999-9999"
                                                    },
                                                    "email": {
                                                        "type": "string",
                                                        "example": "carlos@email.com"
                                                    },
                                                    "empresa": {
                                                        "type": "string",
                                                        "example": "Empresa X"
                                                    },
                                                    "favorite": {
                                                        "type": "boolean",
                                                        "example": true
                                                    },
                                                    "created_at": {
                                                        "type": "string",
                                                        "format": "date-time",
                                                        "example": "2026-07-14T14:30:00.000000Z"
                                                    }
                                                },
                                                "type": "object"
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Usuário não autenticado"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/exports": {
            "get": {
                "tags": [
                    "Exportações"
                ],
                "summary": "Lista todas as exportações do usuário autenticado",
                "operationId": "d25d334b0d44e07cb893c96a709ba949",
                "responses": {
                    "200": {
                        "description": "Lista de exportações retornada com sucesso"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Exportações"
                ],
                "summary": "Solicita uma nova exportação de Contacts",
                "operationId": "d729cf8e078f61999ccf50d4359d8de3",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "formato"
                                ],
                                "properties": {
                                    "formato": {
                                        "description": "Formato do arquivo para exportação",
                                        "type": "string",
                                        "example": "csv",
                                        "enum": [
                                            "csv",
                                            "xlsx",
                                            "pdf"
                                        ]
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Exportação solicitada com sucesso"
                    },
                    "422": {
                        "description": "Formato inválido"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/exports/{id}": {
            "get": {
                "tags": [
                    "Exportações"
                ],
                "summary": "Consulta o status de uma exportação",
                "operationId": "f1f9f4d065d36f6e95adecce1f82fa50",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID da exportação",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Status da exportação retornado com sucesso"
                    },
                    "404": {
                        "description": "Exportação não encontrada"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/exports/{id}/download": {
            "get": {
                "tags": [
                    "Exportações"
                ],
                "summary": "Realiza o download da exportação concluída",
                "operationId": "9e1f5a8ae212030379780e7af1636c9a",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID da exportação",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Arquivo baixado com sucesso"
                    },
                    "400": {
                        "description": "A exportação ainda não foi concluída"
                    },
                    "404": {
                        "description": "Exportação não encontrada"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        }
    },
    "components": {
        "securitySchemes": {
            "sanctum": {
                "type": "apiKey",
                "description": "Autenticação via Laravel Sanctum. O frontend usa sessão de SPA (cookie + CSRF); integrações externas podem usar um token pessoal no formato: Bearer <token>.",
                "name": "Authorization",
                "in": "header"
            }
        }
    },
    "tags": [
        {
            "name": "Auth",
            "description": "Auth"
        },
        {
            "name": "Contacts",
            "description": "Contacts"
        },
        {
            "name": "Dashboard",
            "description": "Dashboard"
        },
        {
            "name": "Exportações",
            "description": "Exportações"
        }
    ]
}