{
  "info": {
    "name": "apiContacts API",
    "_postman_id": "apiContacts-collection",
    "description": "Coleção Postman para a API de Contacts",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Listar Contacts",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" },
          { "key": "Accept", "value": "application/json", "type": "text" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/Contacts",
          "host": ["{{baseUrl}}"],
          "path": ["api", "Contacts"],
          "query": [
            { "key": "search", "value": "" }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Criar Contact",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" },
          { "key": "Accept", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"name Exemplo\",\n  \"phone\": \"+5511999999999\",\n  \"email\": \"exemplo@dominio.com\",\n  \"favorite\": false\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/Contacts",
          "host": ["{{baseUrl}}"],
          "path": ["api", "Contacts"]
        }
      },
      "response": []
    },
    {
      "name": "Ver Contact",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" },
          { "key": "Accept", "value": "application/json", "type": "text" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/Contacts/:id",
          "host": ["{{baseUrl}}"],
          "path": ["api", "Contacts", ":id"]
        }
      },
      "response": []
    },
    {
      "name": "Atualizar Contact",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" },
          { "key": "Accept", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"name Atualizado\",\n  \"phone\": \"+5511988888888\",\n  \"email\": \"novo@dominio.com\",\n  \"favorite\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/Contacts/:id",
          "host": ["{{baseUrl}}"],
          "path": ["api", "Contacts", ":id"]
        }
      },
      "response": []
    },
    {
      "name": "Remover Contact",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" },
          { "key": "Accept", "value": "application/json", "type": "text" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/Contacts/:id",
          "host": ["{{baseUrl}}"],
          "path": ["api", "Contacts", ":id"]
        }
      },
      "response": []
    },
    {
      "name": "Alternar favorite",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" },
          { "key": "Accept", "value": "application/json", "type": "text" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/Contacts/:id/favorite",
          "host": ["{{baseUrl}}"],
          "path": ["api", "Contacts", ":id", "favorite"]
        }
      },
      "response": []
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000" },
    { "key": "token", "value": "" }
  ]
}
